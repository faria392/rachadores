# ============================================
# CONFIGURAÇÃO PARA HOSTINGER
# ============================================
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# AMBIENTE
# ============================================
# development = local com logs detalhados
# production = Hostinger (sem logs de debug)
NODE_ENV=production

# ============================================
# SERVIDOR
# ============================================
# Porta que o servidor vai rodar (Hostinger usa 5000)
PORT=5000
# Host: 0.0.0.0 aceita conexões externas
HOST=0.0.0.0

# ============================================
# BANCO DE DADOS HOSTINGER
# ============================================
# Obtenha estes valores no painel do Hostinger
# Menu: Banco de Dados → Sua base de dados

# Host do banco de dados (ex: db1234.mysql.hostinger.com)
# NÃO use localhost em produção!
DB_HOST=seu_host_hostinger_aqui

# Porta MySQL (padrão: 3306)
DB_PORT=3306

# Usuário do banco de dados
DB_USERNAME=seu_usuario_aqui

# Senha do banco de dados
# NÃO deixe vazio em produção!
DB_PASSWORD=sua_senha_aqui

# Nome da base de dados
DB_NAME=faturamento_competicaos

# ============================================
# SEGURANÇA - JWT
# ============================================
# Gere uma chave forte com: openssl rand -base64 32
# Use uma chave diferente para produção
JWT_SECRET=sua_chave_secreta_super_segura_bem_longa_nao_use_essa

# ============================================
# EXEMPLO DE PREENCHIMENTO
# ============================================
# NODE_ENV=production
# PORT=5000
# HOST=0.0.0.0
# DB_HOST=mysql.seudominio.com.br
# DB_PORT=3306
# DB_USERNAME=seu_user_123
# DB_PASSWORD=Senha@Forte123!
# DB_NAME=faturamento_competicaos
# JWT_SECRET=abcd1234efgh5678ijkl9012mnop3456
